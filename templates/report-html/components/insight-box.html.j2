{# Insight box with corner accents: {% include "components/insight-box.html.j2" %}
   Expects: insight_title, insight_text, insight_color (optional: primary|green|red|purple|amber, default "primary") #}
{% set color_map = {
  "primary": "#576dea",
  "green": "#22c55e",
  "red": "#ef4444",
  "purple": "#a78bfa",
  "amber": "#f59e0b"
} %}
{% set resolved_color = color_map[insight_color | default("primary")] | default("#576dea") %}
<div class="corner-accents border border-slate-200 bg-white p-6 hover:shadow-md transition-shadow duration-200">
  <div class="flex items-start gap-3">
    <div class="h-1 w-1 shrink-0 mt-2.5" style="background: {{ resolved_color }};"></div>
    <div>
      <div class="text-base font-semibold text-slate-900 mb-2">{{ insight_title }}</div>
      <div class="text-base leading-relaxed text-slate-600">{{ insight_text }}</div>
    </div>
  </div>
</div>
