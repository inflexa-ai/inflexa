# Citation File Format 1.2.0  —  https://citation-file-format.github.io/
# GitHub renders a "Cite this repository" button from this file and exports BibTeX/APA.

cff-version: 1.2.0
message: "If you use Inflexa in your research, please cite it as below."
title: "Inflexa"
abstract: >-
    Inflexa is a local-first, open-source CLI agent for reproducible biological
    data analysis. It lets scientists analyze omics and biological datasets from
    the terminal using natural language, runs locally, executes analyses in a
    reproducible Docker sandbox, and records full provenance and lineage in SQLite.
type: software
authors:
    # Citation order matters — listed in the order they will be credited.
    - given-names: "Radu Andrei"
      family-names: Tanasa
      affiliation: "Inflexa, Inc."
      orcid: "https://orcid.org/0009-0007-2817-4589"
    - given-names: Robert
      family-names: Krajla
      affiliation: "Inflexa, Inc."
      orcid: "https://orcid.org/0009-0009-7758-0684"
    - given-names: Stefan
      family-names: Buciu
      affiliation: "Inflexa, Inc."
      orcid: "https://orcid.org/0009-0005-8000-0055"
    - name: "Inflexa, Inc."

version: 0.1.0
date-released: "2026-07-07"
url: "https://inflexa.ai"
repository-code: "https://github.com/inflexa-ai/inflexa"

license: Apache-2.0

keywords:
    - bioinformatics
    - reproducibility
    - provenance
    - data lineage
    - transcriptomics
    - single-cell
    - RNA-seq
    - pathway analysis
    - omics
    - AI agent
    - command-line tool

doi: "10.5281/zenodo.21361439"
identifiers:
    - type: doi
      value: "10.5281/zenodo.21361439"
      description: "Concept DOI — always resolves to the latest Inflexa release."
    - type: doi
      value: "10.5281/zenodo.21361440"
      description: "Version DOI — Inflexa v0.1.0 specifically."

