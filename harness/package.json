{
  "name": "@inflexa-ai/harness",
  "version": "0.0.1",
  "description": "Host-agnostic bioinformatics agent harness — hand-rolled agent loop, DBOS-durable workflows, sandboxed compute.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/inflexa-ai/inflexa.git",
    "directory": "harness"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write src/",
    "format:file": "prettier --write",
    "lint": "eslint .",
    "prepare": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.5",
    "@ai-sdk/openai-compatible": "^3.0.3",
    "@ai-sdk/provider": "^4.0.1",
    "@anthropic-ai/sdk": "^0.107.0",
    "@dbos-inc/dbos-sdk": "^4.23.0",
    "@kubernetes/client-node": "^1.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "ai": "^7.0.11",
    "cheerio": "^1.0.0",
    "dockerode": "^4.0.0",
    "fast-xml-parser": "^5.7.0",
    "hono": "^4.0.0",
    "js-tiktoken": "^1.0.0",
    "mime": "^4.0.0",
    "nanoid": "^5.0.0",
    "neverthrow": "^8.2.0",
    "nunjucks": "^3.2.4",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "puppeteer-core": "^23.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/dockerode": "^3.3.0",
    "@types/node": "^24.0.0",
    "@types/nunjucks": "^3.2.6",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.0",
    "eslint": "^10.4.1",
    "eslint-plugin-neverthrow": "^1.1.4",
    "globals": "^17.6.0",
    "prettier": "^3.8.1",
    "testcontainers": "^10.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "patchedDependencies": {
    "eslint-plugin-neverthrow@1.1.4": "patches/eslint-plugin-neverthrow@1.1.4.patch"
  }
}
