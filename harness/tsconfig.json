{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@inflexa-ai/harness": ["./src/index.ts"],
      "@inflexa-ai/harness/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/**/*.test.ts", "src/**/__tests__"]
}
