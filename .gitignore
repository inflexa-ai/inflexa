# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

.env
node_modules
dist
dist-docs
dist-ssr
*.local

# TypeScript incremental build info
*.tsbuildinfo

# Python bytecode cache (e.g. from scripts/lib-validator/*.py smoke tests)
__pycache__/
*.py[cod]

# Guard against tsc emitting alongside source. the harness builds to harness/dist (ignored
# above); these catch an accidental in-place emit. Scoped to core, NOT blanket
# **/src — cli/src ships a hand-written assets.d.ts that must stay tracked.
harness/src/**/*.js
harness/src/**/*.d.ts

# sandbox-server Go binary: built into the image, never committed
images/sandbox-base/server/sandbox-server

# Bundled skills/templates archive: generated by cli/scripts/build.ts and embedded into the binary
cli/content.pack

# bun is the package manager; npm/yarn lockfiles must not be committed
package-lock.json
yarn.lock

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.playwright-mcp/
.claude/worktrees/

# SSL certificates (generated by .dev/setup-ssl.sh)
.dev/*.pem

todos/
./*.png
.screenshots/
.auth/
tech-debt/
.superpowers/

.old_ideas/

# Python bytecode (e.g. scripts/lib-store-validate)
__pycache__/
*.pyc

# Paper working directory — manuscript scaffold and reference PDFs, kept local
# only (a journal treats a public preprint as prior publication).
paper/

# Anchor-marker dirs minted by running inflexa inside the repo (dev/E2E runs) — local workspace identity, never repo content
.inflexa/
