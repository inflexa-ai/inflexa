{# Fixed left-side report navigation: {% include "components/sidebar.html.j2" %}
   Expects: sidebar_items — list of { id, label, icon (optional inline SVG content) }
   Optional: sidebar_brand (default "inflexa"), sidebar_brand_label, sidebar_footer
   The active link is tracked by an IntersectionObserver in base.html.j2 — each
   item.id MUST match a corresponding `id="…"` on a <section> in the page.
   Numeric step badges are auto-rendered when an item has no `icon`. #}
<aside id="report-sidebar"
       class="fixed top-0 left-0 z-40 h-screen w-60 flex flex-col border-r border-slate-200 bg-white/95 backdrop-blur transform -translate-x-full lg:translate-x-0 transition-transform duration-200"
       aria-label="Report navigation">
  <div class="flex items-center gap-2 px-5 py-5 border-b border-slate-200">
    <span class="font-mono text-sm font-semibold tracking-wider text-primary-500">{{ sidebar_brand | default("inflexa") }}</span>
    {% if sidebar_brand_label %}
    <span class="text-slate-300">|</span>
    <span class="font-mono text-[11px] font-semibold tracking-wider text-slate-400 uppercase">{{ sidebar_brand_label }}</span>
    {% endif %}
  </div>
  <nav class="flex-1 overflow-y-auto py-3" aria-label="Report sections">
    {% for item in sidebar_items %}
    <a href="#{{ item.id }}" data-sidebar-link
       class="sidebar-link flex items-center gap-3 px-5 py-2 text-sm text-slate-500 hover:text-slate-900 hover:bg-slate-50 transition-colors">
      {% if item.icon %}
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
           class="shrink-0">{{ item.icon | safe }}</svg>
      {% else %}
      <span class="font-mono text-[10px] font-semibold tracking-wider text-slate-300 shrink-0 w-4 text-right">{{ loop.index }}</span>
      {% endif %}
      <span class="truncate">{{ item.label }}</span>
    </a>
    {% endfor %}
  </nav>
  {% if sidebar_footer %}
  <div class="px-5 py-4 border-t border-slate-200 text-xs text-slate-400">{{ sidebar_footer | safe }}</div>
  {% endif %}
</aside>

<button id="sidebar-mobile-toggle" type="button"
        class="lg:hidden fixed top-3 right-3 z-50 inline-flex items-center justify-center h-9 w-9 rounded-md border border-slate-200 bg-white text-slate-700 shadow-sm hover:bg-slate-50 transition-colors"
        aria-label="Toggle navigation" aria-controls="report-sidebar" aria-expanded="false">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
       stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <line x1="3" y1="6" x2="21" y2="6"></line>
    <line x1="3" y1="12" x2="21" y2="12"></line>
    <line x1="3" y1="18" x2="21" y2="18"></line>
  </svg>
</button>
