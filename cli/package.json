{
    "name": "inflexa",
    "version": "0.3.6",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "bun scripts/build.ts",
        "build:all": "bun scripts/build.ts --all",
        "dev": "bun run src/index.ts",
        "dev:install": "bun scripts/dev_install.ts",
        "docs:gen": "bun scripts/gen_docs.ts",
        "format": "prettier --write src/",
        "format:file": "prettier --write",
        "harness:local": "cd ../harness && bun run build && bun link && cd ../cli && bun link @inflexa-ai/harness",
        "harness:remote": "rm -rf node_modules/@inflexa-ai/harness && bun install",
        "lint": "eslint .",
        "start": "bun run src/index.ts",
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "wipe": "bun scripts/wipe.ts"
    },
    "dependencies": {
        "@clack/prompts": "^1.7.0",
        "@inflexa-ai/harness": "0.6.0",
        "@inflexa-ai/tsprov": "0.5.1",
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/api-logs": "^0.219.0",
        "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
        "@opentelemetry/resources": "^2.9.0",
        "@opentelemetry/sdk-logs": "^0.219.0",
        "@opentelemetry/semantic-conventions": "^1.43.0",
        "@opentui/core": "0.4.2",
        "@opentui/solid": "0.4.2",
        "commander": "^15",
        "neverthrow": "^8.2.0",
        "pino": "^10.3.1",
        "solid-js": "^1.9.14",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "latest",
        "@types/node": "^26.1.1",
        "eslint": "^10.7.0",
        "eslint-plugin-neverthrow": "^1.1.4",
        "eslint-plugin-solid": "^0.14.5",
        "globals": "^17.6.0",
        "prettier": "^3.9.5",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.64.0"
    },
    "patchedDependencies": {
        "eslint-plugin-neverthrow@1.1.4": "patches/eslint-plugin-neverthrow@1.1.4.patch"
    }
}
